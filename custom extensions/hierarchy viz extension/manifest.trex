<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.squareshift.hierarchytreeviz" extension-version="2.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>Hierarchy Tree Visualization — top-to-bottom L2→L3→L4 with metrics</description>
    <author name="SQS" email="[EMAIL_ADDRESS]" organization="SquareShitf" website="https://zscaler.com"/>
    <min-api-version>1.1</min-api-version>
    <source-location>
      <url>http://localhost:8766/index.html</url>
    </source-location>
    <icon>iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==</icon>
    <permissions>
      <permission>full data</permission>
    </permissions>
    <context-menu>
      <configure-context-menu-item />
    </context-menu>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">Hierarchy Tree Visualization</text>
    </resource>
  </resources>
</manifest>
